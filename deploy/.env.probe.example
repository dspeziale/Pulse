# =============================================================================
# Pulse — variabili per lo stack PROBE (deploy/docker-compose.probe.yml).
# Copiare in `deploy/.env.probe` e valorizzare. NON committare i segreti.
# =============================================================================

# --- OpenSearch ---
OPENSEARCH_ADMIN_PASSWORD=Pulse_OS_Admin1!

# --- Probe agent (FastAPI) ---
PULSE_PROBE_API_PORT=8444
# URL del Server (endpoint dedicati Probe, porta mTLS 9443 in produzione).
PULSE_PROBE_SERVER_BASE_URL=https://server-backend:9443
# Token di enrollment monouso ottenuto creando la Probe nel Server (una volta).
PULSE_PROBE_ENROLLMENT_TOKEN=
# In alternativa, token per-Probe gia' emesso.
PULSE_PROBE_PROBE_TOKEN=
# Token che il Server presenta alle API di query della Probe (deve combaciare
# con PULSE_PROBE_QUERY_TOKEN del Server).
PULSE_PROBE_SERVER_QUERY_TOKEN=server-to-probe-token
PULSE_PROBE_HTTP_VERIFY=false
PULSE_PROBE_LOG_LEVEL=info

# --- Dashboard Probe (Flask, FE) ---
PULSE_PROBE_DASH_PORT=5001
PULSE_PROBE_DASH_USER=probe
PULSE_PROBE_DASH_PASSWORD=probe
PULSE_PROBE_SECRET_KEY=dev-probe-secret
PULSE_HTTP_TIMEOUT=10
PULSE_VERIFY_TLS=false
