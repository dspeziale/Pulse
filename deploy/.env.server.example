# =============================================================================
# Pulse — variabili per lo stack SERVER (deploy/docker-compose.server.yml).
# Copiare in `deploy/.env.server` e valorizzare. NON committare i segreti.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

# --- Backend (FastAPI) ---
PULSE_API_PORT=8443
# In produzione: segreto lungo e casuale.
PULSE_JWT_SECRET=change-me-in-production-please-set-a-long-random-secret
# Chiave Fernet (urlsafe-b64, 32 byte); se vuota viene derivata dal JWT secret.
PULSE_SECRETS_ENCRYPTION_KEY=
# Token applicativo presentato dal Server alle API di query delle Probe.
PULSE_PROBE_QUERY_TOKEN=server-to-probe-token
PULSE_WORKERS=2
PULSE_LOG_LEVEL=info

# --- Dashboard Server (Flask, FE) ---
PULSE_SERVER_DASH_PORT=5000
PULSE_SERVER_SECRET_KEY=dev-server-secret
PULSE_HTTP_TIMEOUT=10
# false in ambienti senza certificati TLS validi (sviluppo).
PULSE_VERIFY_TLS=false
# Nome cookie di sessione (deve differire da quello della dashboard Probe).
PULSE_SERVER_SESSION_COOKIE_NAME=pulse_server_session
# Cookie Secure: true solo dietro HTTPS.
PULSE_SERVER_SESSION_COOKIE_SECURE=false
