# =============================================================================
# Pulse - PACCHETTO SONDA: variabili di ambiente
# File: deploy/probe-package/.env.probe.example
#
# COPIARE questo file in `.env` (stessa cartella) e valorizzarlo:
#     cp .env.probe.example .env        (Linux/macOS)
#     Copy-Item .env.probe.example .env (Windows PowerShell)
# Lo script install.sh / install.ps1 esegue questa copia automaticamente se
# `.env` non esiste.
#
# NON committare `.env`: contiene segreti. Qui NON ci sono segreti reali, solo
# valori di esempio/placeholder.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenSearch (archivio locale serie temporali della Sonda)
# -----------------------------------------------------------------------------
# Password admin di OpenSearch. In modalita' sviluppo il plugin di sicurezza e'
# disabilitato (DISABLE_SECURITY_PLUGIN=true nel compose) quindi non viene usata
# per l'autenticazione, ma va comunque impostata (requisito immagine >= 2.12).
# Cambiala con un valore robusto in produzione.
OPENSEARCH_ADMIN_PASSWORD=Pulse_OS_Admin1!

# -----------------------------------------------------------------------------
# Probe agent (FastAPI) - variabili con prefisso PULSE_PROBE_
# -----------------------------------------------------------------------------

# Porta HTTP su cui l'agent espone le API (health + query). Deve essere libera
# sull'host ed eventualmente raggiungibile dal Server per il drill-down.
PULSE_PROBE_API_PORT=8444

# URL del Server Pulse RAGGIUNGIBILE DALLA SONDA (endpoint dedicati Probe).
# In produzione tipicamente porta mTLS 9443. Esempi:
#   https://pulse-server.miodominio.it:9443
#   https://192.168.10.20:9443
# OBBLIGATORIO: sostituire il placeholder con l'URL reale del tuo Server.
PULSE_PROBE_SERVER_BASE_URL=https://CAMBIAMI-server:9443

# Token di ENROLLMENT MONOUSO ottenuto creando la Probe nel Server (dashboard
# Sonde -> Nuova, oppure API POST /api/v1/probes). Serve al PRIMO contatto per
# ottenere il probe_token per-Sonda.
# OBBLIGATORIO al primo avvio (se non usi PULSE_PROBE_PROBE_TOKEN).
# ATTENZIONE: e' monouso. Vedi INSTALL.md > Troubleshooting (riavvio/rotazione).
PULSE_PROBE_ENROLLMENT_TOKEN=

# In ALTERNATIVA all'enrollment: token per-Probe gia' emesso (es. dopo una
# rotazione delle credenziali dal Server). Lasciare vuoto se usi l'enrollment.
PULSE_PROBE_PROBE_TOKEN=

# Token che il Server presenta alle API di query della Probe (drill-down).
# DEVE combaciare con PULSE_PROBE_QUERY_TOKEN configurato sul Server per questa
# Sonda. Cambiare il valore di default in produzione.
PULSE_PROBE_SERVER_QUERY_TOKEN=server-to-probe-token

# Verifica del certificato TLS quando la Sonda chiama il Server.
#   false = accetta certificati self-signed (tipico in sviluppo/lab)
#   true  = verifica la catena (produzione con certificati validi)
PULSE_PROBE_HTTP_VERIFY=false

# Livello di log dell'agent: debug | info | warning | error
PULSE_PROBE_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Dashboard locale della Sonda (Flask)
# -----------------------------------------------------------------------------

# Porta HTTP della dashboard locale della Sonda.
PULSE_PROBE_DASH_PORT=5001

# Credenziali di accesso alla dashboard locale. CAMBIARLE in produzione.
PULSE_PROBE_DASH_USER=probe
PULSE_PROBE_DASH_PASSWORD=probe

# Chiave segreta Flask per firmare le sessioni. Generarne una casuale in
# produzione, es.:  python -c "import secrets; print(secrets.token_hex(32))"
PULSE_PROBE_SECRET_KEY=dev-probe-secret

# Nome del cookie di sessione (deve differire da quello della dashboard Server
# se le due girano sullo stesso browser/host).
PULSE_PROBE_SESSION_COOKIE_NAME=pulse_probe_session

# Cookie Secure: true SOLO se la dashboard e' servita dietro HTTPS.
PULSE_PROBE_SESSION_COOKIE_SECURE=false

# Timeout (secondi) delle chiamate HTTP dalla dashboard verso l'agent.
PULSE_HTTP_TIMEOUT=10

# Verifica TLS delle chiamate dalla dashboard verso l'agent (interne alla rete
# Docker: normalmente false).
PULSE_VERIFY_TLS=false
