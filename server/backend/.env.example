# =============================================================================
# Pulse Server backend — variabili d'ambiente (prefisso PULSE_).
# Copiare in `.env` e valorizzare. Tutte le variabili sono opzionali: hanno
# default applicativi (vedi pulse_server/config.py). I segreti NON vanno
# committati.
# =============================================================================

# --- Database PostgreSQL (schema/seed del DBA in deploy/schema.sql+seed.sql) ---
# Formato SQLAlchemy + driver psycopg (v3).
PULSE_DATABASE_URL=postgresql+psycopg://pulse:pulse@postgres:5432/pulse

# --- Porte applicative (DOCUMENTO_API §Convenzioni) ---
PULSE_API_PORT=8443
PULSE_PROBE_ENDPOINT_PORT=9443

# --- JWT / autenticazione (RF-002) ---
# In produzione impostare un segreto forte e casuale.
PULSE_JWT_SECRET=change-me-in-production-please-set-a-long-random-secret
PULSE_JWT_ALGORITHM=HS256
PULSE_ACCESS_TOKEN_TTL_SECONDS=900
PULSE_REFRESH_TOKEN_TTL_SECONDS=1209600
PULSE_FAILED_LOGIN_THRESHOLD=5

# --- Cifratura segreti canali a riposo (RNF-004) ---
# Chiave Fernet urlsafe-base64 (32 byte). Se assente, derivata da JWT_SECRET.
PULSE_SECRETS_ENCRYPTION_KEY=

# --- Enrollment Probe / liveness ---
PULSE_ENROLLMENT_TOKEN_TTL_SECONDS=3600
PULSE_PROBE_OFFLINE_TIMEOUT_SECONDS=120

# --- mTLS / PKI Server<->Probe (QT-02). Path ai certificati montati nel container ---
# Il TLS/mTLS si attiva a livello di trasporto (uvicorn --ssl-* o reverse proxy).
# A livello applicativo si valida il token per-Probe. Vedi README §Sicurezza.
PULSE_TLS_CA_CERT_PATH=
PULSE_TLS_SERVER_CERT_PATH=
PULSE_TLS_SERVER_KEY_PATH=
PULSE_SERVER_PROBE_ENDPOINT=https://localhost:9443

# --- Client HTTP verso le Probe (drill-down proxy) ---
PULSE_PROBE_HTTP_TIMEOUT_SECONDS=10
PULSE_PROBE_CLIENT_CERT_PATH=
PULSE_PROBE_CLIENT_KEY_PATH=
# Token applicativo presentato dal Server alla API di query della Probe.
PULSE_PROBE_QUERY_TOKEN=server-to-probe-token

# --- Logging ---
PULSE_LOG_LEVEL=info

# --- Rate limiting inbound (webhook canali) ---
PULSE_INBOUND_RATE_LIMIT_PER_MINUTE=60

# --- Numero di worker gunicorn (usato dal Dockerfile) ---
PULSE_WORKERS=2
