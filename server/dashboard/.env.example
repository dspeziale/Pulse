# Dashboard SERVER Pulse — variabili d'ambiente (copiare in .env).

# URL base del backend FastAPI del Server (sezione BACKEND del DOCUMENTO_API).
PULSE_SERVER_API_BASE=http://localhost:8000/api/v1

# Chiave segreta Flask per firmare la sessione (OBBLIGATORIO cambiarla in produzione).
PULSE_SERVER_SECRET_KEY=change-me-in-production

# Porta di ascolto dell'app Flask (default 5000).
PULSE_SERVER_DASH_PORT=5000

# Timeout (secondi) delle chiamate HTTP verso il backend.
PULSE_HTTP_TIMEOUT=10

# Verifica dei certificati TLS nelle chiamate verso il backend (true/false).
PULSE_VERIFY_TLS=true
