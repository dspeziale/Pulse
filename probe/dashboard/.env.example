# Dashboard PROBE Pulse — variabili d'ambiente (copiare in .env).

# URL base del probe-agent (sezione BACKEND: "Endpoint sulla PROBE", /api/v1).
PULSE_PROBE_API_BASE=http://localhost:8444/api/v1

# Token Bearer per interrogare gli endpoint del probe-agent (decisione FE-03).
PULSE_PROBE_AGENT_TOKEN=

# Credenziali di login locale della dashboard Probe (decisione FE-02).
# OBBLIGATORIO cambiarle in produzione.
PULSE_PROBE_DASH_USER=probe
PULSE_PROBE_DASH_PASSWORD=change-me-in-production

# Chiave segreta Flask per firmare la sessione (OBBLIGATORIO cambiarla).
PULSE_PROBE_SECRET_KEY=change-me-in-production

# Porta di ascolto dell'app Flask (default 5001).
PULSE_PROBE_DASH_PORT=5001

# Timeout (secondi) delle chiamate HTTP verso il probe-agent.
PULSE_HTTP_TIMEOUT=10

# Verifica dei certificati TLS nelle chiamate verso il probe-agent (true/false).
PULSE_VERIFY_TLS=true

# Nome del cookie di sessione Flask. DEVE differire da quello della dashboard
# Server: su localhost i cookie non distinguono la porta e un nome condiviso
# farebbe deautenticare l'utente aprendo entrambe le dashboard (default:
# pulse_probe_session).
PULSE_PROBE_SESSION_COOKIE_NAME=pulse_probe_session

# Attributo Secure del cookie di sessione. Lasciare false in HTTP (sviluppo);
# impostare true solo dietro HTTPS.
PULSE_PROBE_SESSION_COOKIE_SECURE=false

# Fuso orario IANA per la visualizzazione delle date-ora nella dashboard Probe
# (default Europe/Rome). La dashboard Probe non accede alla config del Server,
# quindi usa questa variabile. Es.: UTC, Europe/London, America/New_York.
PULSE_PROBE_TIMEZONE=Europe/Rome
