# Esempio di configurazione del proxy nmap (host Windows).
# In produzione questo file e' generato dall'installer in
#   C:\ProgramData\Pulse\nmap-proxy\.env
PULSE_NMAP_PROXY_HOST=0.0.0.0
PULSE_NMAP_PROXY_PORT=8556
# Token Bearer condiviso con l'agent (obbligatorio).
PULSE_NMAP_PROXY_TOKEN=change-me
# mTLS: certificato/chiave del server + CA che firma i certificati CLIENT.
PULSE_NMAP_PROXY_TLS_CERT_PATH=C:\ProgramData\Pulse\nmap-proxy\certs\server.crt
PULSE_NMAP_PROXY_TLS_KEY_PATH=C:\ProgramData\Pulse\nmap-proxy\certs\server.key
PULSE_NMAP_PROXY_TLS_CLIENT_CA_PATH=C:\ProgramData\Pulse\nmap-proxy\certs\ca.crt
# Percorso di nmap nativo (Windows).
PULSE_NMAP_PROXY_NMAP_PATH=C:\Program Files (x86)\Nmap\nmap.exe
PULSE_NMAP_PROXY_MAX_SCAN_TIMEOUT=3600
