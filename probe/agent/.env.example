# =============================================================================
# Pulse Probe agent — variabili d'ambiente (prefisso PULSE_PROBE_).
# Copiare in `.env` e valorizzare. I segreti NON vanno committati.
# =============================================================================

# --- Identita' e porta ---
PULSE_PROBE_PROBE_ID=
PULSE_PROBE_API_PORT=8444
PULSE_PROBE_HOSTNAME=probe-local

# --- Comunicazione col Server (endpoint dedicati §1.9) ---
PULSE_PROBE_SERVER_BASE_URL=https://server:9443
# Token per-Probe: se assente e c'e' un enrollment_token, la Probe si registra.
PULSE_PROBE_PROBE_TOKEN=
PULSE_PROBE_ENROLLMENT_TOKEN=

# --- Token presentato dal Server alle API di query della Probe ---
PULSE_PROBE_SERVER_QUERY_TOKEN=server-to-probe-token

# --- OpenSearch locale (se assente/irraggiungibile: storage in-memory degradato) ---
PULSE_PROBE_OPENSEARCH_URL=http://opensearch:9200
PULSE_PROBE_OPENSEARCH_USER=
PULSE_PROBE_OPENSEARCH_PASSWORD=
PULSE_PROBE_OPENSEARCH_VERIFY_CERTS=false
PULSE_PROBE_HEARTBEAT_INDEX=pulse-heartbeats
PULSE_PROBE_EVENTS_INDEX=pulse-events

# --- Poller ---
PULSE_PROBE_POLL_DEFAULT_INTERVAL_SECONDS=30
PULSE_PROBE_POLL_DEFAULT_TIMEOUT_SECONDS=5
PULSE_PROBE_CONFIG_REFRESH_SECONDS=60
PULSE_PROBE_ROLLUP_WINDOW=1h
PULSE_PROBE_POLLER_ENABLED=true

# --- mTLS (path certificati montati nel container) ---
PULSE_PROBE_TLS_CA_CERT_PATH=
PULSE_PROBE_TLS_CLIENT_CERT_PATH=
PULSE_PROBE_TLS_CLIENT_KEY_PATH=
PULSE_PROBE_HTTP_VERIFY=false

# --- Logging ---
PULSE_PROBE_LOG_LEVEL=info
